{
  "$description": "Nowa design system tokens. Source: pages/index-v2.html + index-permill.html. Locked variant: canvas = Sunlit cream (paper3), hero = Stage (1).",
  "color": {
    "coral-flame": { "$value": "#ef493d", "$type": "color", "$description": "THE action color. CTAs only — never decorative." },
    "coral-glow": { "$value": "#f87a71", "$type": "color", "$description": "Coral on dark surfaces / hover lift." },
    "coral-blush": { "$value": "#fececa", "$type": "color", "$description": "Soft coral. Pixel offset shadow, egg spot." },
    "ember-deep": { "$value": "#b9271c", "$type": "color", "$description": "Button side face / pressed shadow." },
    "ember-darker": { "$value": "#7f241d", "$type": "color", "$description": "Brand dark accent surface." },
    "deep-ink": { "$value": "#161c24", "$type": "color", "$description": "Primary text and dark canvas." },
    "ink-charcoal": { "$value": "#212b36", "$type": "color", "$description": "Dark card faces, device frames." },
    "slate-mid": { "$value": "#454f5b", "$type": "color", "$description": "Secondary text." },
    "mist-body": { "$value": "#637381", "$type": "color", "$description": "Tertiary / muted text." },
    "cloud-border": { "$value": "#c4cdd5", "$type": "color", "$description": "Borders / muted text on dark." },
    "chalk-surface": { "$value": "#dfe3e8", "$type": "color", "$description": "Alt band surface, inactive meter cells." },
    "warm-parchment": { "$value": "#fdf5dd", "$type": "color", "$description": "CANVAS — Sunlit cream (paper3), locked." },
    "ghost-white": { "$value": "#f4f6f8", "$type": "color", "$description": "Level-1 surface / blueprint fill." },
    "pure-white": { "$value": "#ffffff", "$type": "color", "$description": "Card faces, modals." },
    "amber-signal": { "$value": "#ffc107", "$type": "color", "$description": "Pixel sparkle, sample chip, device button." },
    "leaf-success": { "$value": "#54d62c", "$type": "color", "$description": "Beta chip, success state." },
    "parchment-original": { "$value": "#edeae2", "$type": "color", "$description": "Theme 1a — original parchment (not active)." },
    "parchment-ivory": { "$value": "#f6f0e1", "$type": "color", "$description": "Theme 1b — brighter ivory (not active)." }
  },
  "surface": {
    "level-0-canvas": { "$value": "{color.warm-parchment}", "$type": "color", "$description": "Base canvas." },
    "level-1": { "$value": "{color.ghost-white}", "$type": "color" },
    "level-2": { "$value": "{color.chalk-surface}", "$type": "color" },
    "level-3": { "$value": "{color.pure-white}", "$type": "color", "$description": "Card faces / floating." },
    "level-4-ink": { "$value": "{color.deep-ink}", "$type": "color", "$description": "Dark night sections." },
    "level-5-brand": { "$value": "{color.ember-darker}", "$type": "color" }
  },
  "font": {
    "family": {
      "onest": { "$value": "Onest", "$type": "fontFamily", "$description": "Display, headings, UI labels." },
      "noto-sans": { "$value": "Noto Sans", "$type": "fontFamily", "$description": "Body copy." },
      "pixel-tiny5": { "$value": "Tiny5", "$type": "fontFamily", "$description": "PET-WORLD ONLY — pet sounds, levels, numbers, species names." }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" },
      "black": { "$value": 900, "$type": "fontWeight" }
    },
    "size": {
      "caption": { "$value": "12px", "$type": "dimension" },
      "body-sm": { "$value": "14px", "$type": "dimension" },
      "body": { "$value": "16px", "$type": "dimension" },
      "subheading": { "$value": "18px", "$type": "dimension" },
      "heading-sm": { "$value": "20px", "$type": "dimension" },
      "heading": { "$value": "24px", "$type": "dimension" },
      "heading-lg": { "$value": "30px", "$type": "dimension" },
      "heading-xl": { "$value": "36px", "$type": "dimension" },
      "display-alt": { "$value": "48px", "$type": "dimension" },
      "display": { "$value": "64px", "$type": "dimension" }
    }
  },
  "spacing": {
    "4": { "$value": "4px", "$type": "dimension" },
    "8": { "$value": "8px", "$type": "dimension" },
    "12": { "$value": "12px", "$type": "dimension" },
    "16": { "$value": "16px", "$type": "dimension" },
    "24": { "$value": "24px", "$type": "dimension" },
    "32": { "$value": "32px", "$type": "dimension" },
    "40": { "$value": "40px", "$type": "dimension" },
    "48": { "$value": "48px", "$type": "dimension" },
    "64": { "$value": "64px", "$type": "dimension" },
    "96": { "$value": "96px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Tags." },
    "md": { "$value": "8px", "$type": "dimension", "$description": "Nav, inputs." },
    "cards": { "$value": "16px", "$type": "dimension" },
    "cards-lg": { "$value": "24px", "$type": "dimension" },
    "modals": { "$value": "32px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Soft pills (web). Note: pixel system uses stepped corners instead." }
  },
  "pixel": {
    "grid-cell": { "$value": "28px", "$type": "dimension", "$description": "Graph-paper module size." },
    "grid-line": { "$value": "rgba(22,28,36,.08)", "$type": "color", "$description": "Graph-paper line on light." },
    "grid-line-dark": { "$value": "rgba(255,255,255,.06)", "$type": "color", "$description": "Graph-paper line on ink." },
    "step-sm": { "$value": "8px", "$type": "dimension", "$description": "Stepped-corner notch — small elements." },
    "step-md": { "$value": "12px", "$type": "dimension", "$description": "Stepped-corner notch — cards/avatars." },
    "shadow": { "$value": "3px 3px 0 rgba(22,28,36,.12)", "$type": "shadow", "$description": "Hard pixel drop shadow on light." },
    "shadow-dark": { "$value": "3px 3px 0 rgba(0,0,0,.18)", "$type": "shadow", "$description": "Hard pixel drop shadow on ink." },
    "shadow-pop": { "$value": "14px 14px 0 #fececa", "$type": "shadow", "$description": "Hero stage offset (coral-blush)." }
  },
  "motion": {
    "ease-default": { "$value": "cubic-bezier(.4,0,.2,1)", "$type": "cubicBezier" },
    "ease-expo": { "$value": "cubic-bezier(0.19,1,0.22,1)", "$type": "cubicBezier", "$description": "Reveals / entrances." },
    "ease-out-strong": { "$value": "cubic-bezier(0.23,1,0.32,1)", "$type": "cubicBezier", "$description": "UI transitions." },
    "duration-fast": { "$value": "150ms", "$type": "duration" },
    "duration-base": { "$value": "300ms", "$type": "duration" },
    "duration-reveal": { "$value": "700ms", "$type": "duration" },
    "duration-reveal-lg": { "$value": "900ms", "$type": "duration" }
  }
}
